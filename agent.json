{
  "name": "ability-memory",
  "type": "ability",
  "version": "0.0.12",
  "description": "Domain layer for conversational agent memory — thin wrapper over graph-ability providing 7 memory-* tools with enforced Memory schema defaults",
  "entrypoint": "dist/index.js",
  "abilities": {
    "ability-graph": "^0.1.2",
    "secret-ability": "*"
  },
  "brokers": {
    "remote": "wss://broker.dadavidtseng.com/kadi"
  },
  "scripts": {
    "preflight": "node --version",
    "setup": "npm install && npm run build",
    "build": "npx tsc",
    "start": "node dist/index.js broker",
    "dev": "npx tsx src/index.ts",
    "clean": "rm -rf node_modules abilities agent-lock.json package-lock.json dist"
  },
  "build": {
    "default": {
      "image": "ability-memory:0.0.12",
      "from": "node:22-slim",
      "platform": "linux/amd64",
      "cli": "latest",
      "run": [
        "npm ci",
        "npm run build",
        "kadi install kadi-install",
        "kadi install kadi-run",
        "kadi install kadi-secret",
        "kadi install"
      ],
      "cmd": [
        "sh",
        "-c",
        "kadi run start"
      ]
    }
  },
  "deploy": {
    "local": {
      "target": "local",
      "engine": "docker",
      "services": {
        "agent": {
          "image": "ability-memory:0.0.12",
          "command": [
            "sh",
            "-c",
            "kadi secret receive --vault model-manager && kadi run start"
          ]
        }
      },
      "secrets": {
        "vault": "model-manager",
        "required": [
          "MODEL_MANAGER_BASE_URL",
          "MODEL_MANAGER_API_KEY"
        ],
        "delivery": "broker"
      }
    },
    "akash": {
      "target": "akash",
      "network": "mainnet",
      "deposit": "10",
      "blacklist": [
        "akash1sevd2ymtty3dpq9ycxgkhuzzk4fe6mchqdwd4e",
        "akash14w36hwrtuqqa3j92fa8ctcxlhjgvr3a0zpp7cj"
      ],
      "engine": "podman",
      "services": {
        "agent": {
          "image": "ability-memory:0.0.12",
          "command": [
            "sh",
            "-c",
            "kadi secret receive --vault model-manager && kadi run start"
          ],
          "expose": [
            {
              "port": 3000,
              "as": 80,
              "to": [
                {
                  "global": true
                }
              ]
            }
          ],
          "resources": {
            "cpu": 0.5,
            "memory": "512Mi",
            "ephemeralStorage": "1Gi"
          },
          "pricing": {
            "amount": "500",
            "denom": "uact"
          }
        }
      },
      "secrets": {
        "vault": "model-manager",
        "required": [
          "MODEL_MANAGER_BASE_URL",
          "MODEL_MANAGER_API_KEY"
        ],
        "delivery": "broker"
      }
    }
  }
}
